# ── Google Cloud / Vertex AI ──────────────────────────────
# Service-account key with role "Vertex AI User". Keep the file OUTSIDE the repo.
GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\your\gcp-key.json
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1

ORCHESTRATOR_MODEL=gemini-2.5-flash
AGENT_MODEL=gemini-2.5-pro
EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIM=768

# ── Pinecone (free Starter tier) ──────────────────────────
PINECONE_API_KEY=
PINECONE_INDEX=fintra-kb

# ── Supabase (free tier) ──────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# ── Behaviour ─────────────────────────────────────────────
MEMORY_WINDOW=10
RETRIEVAL_K=4
RETRIEVAL_FETCH_K=10
RETRIEVAL_LAMBDA=0.5
